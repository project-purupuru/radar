{
  "name": "radar",
  "version": "0.1.0",
  "description": "Solana on-chain event indexer for the Puru ecosystem",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "fmt": "biome format --write src/"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@hono/node-server": "^1.13.7",
    "@solana/web3.js": "^1.98.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.11.0"
}
